{
    "rewrites": [
        {
            "source": "/sitemap.xml",
            "destination": "/api/sitemap"
        },
        {
            "source": "/((?!api|assets|admin|login|favicon.ico|robots.txt|sitemap.xml|social-preview.png).*)",
            "destination": "/api/og?path=$1"
        }
    ]
}